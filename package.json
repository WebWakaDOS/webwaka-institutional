{
  "name": "@webwaka/institutional",
  "version": "0.1.0",
  "description": "WebWaka Institutional Suite — Schools, Universities, and Training Centres on WebWaka OS v4",
  "private": true,
  "scripts": {
    "dev": "WRANGLER_SEND_METRICS=false wrangler dev --port 5000 --ip 0.0.0.0",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@webwaka/core": "^1.3.2",
    "dexie": "^3.2.7",
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240725.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.5.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.80.0"
  }
}
